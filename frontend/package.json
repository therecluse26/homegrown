{
  "name": "homegrown-academy",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "npm run dev:infra && concurrently -n api,web -c blue,green \"cd .. && air\" \"vite\"",
    "dev:infra": "docker compose -f ../docker-compose.yml up -d",
    "dev:infra:down": "docker compose -f ../docker-compose.yml down",
    "dev:api": "cd .. && air",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "convert-spec": "swagger2openapi ../openapi/swagger.json -o ../openapi/openapi3.json",
    "generate-types": "npm run convert-spec && openapi-typescript ../openapi/openapi3.json -o src/api/generated/schema.ts",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test e2e/a11y.spec.ts"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5",
    "lucide-react": "^1.7.0",
    "react": "^19",
    "react-dom": "^19",
    "react-intl": "^10.1.1",
    "react-router": "^7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "openapi-typescript": "^7",
    "swagger2openapi": "^7",
    "tailwindcss": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "vite": "^6"
  }
}
