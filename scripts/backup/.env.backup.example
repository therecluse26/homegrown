# Homegrown Academy — Backup Configuration
# Copy to .env.backup on the server and chmod 600.
# Source it before running backup scripts: source .env.backup

# ── PostgreSQL connection ─────────────────────────────────────────────────────
PGHOST=localhost
PGPORT=5432
PGUSER=homegrown
PGPASSWORD=changeme
PGDATABASE=homegrown

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
# Store in a secrets manager in production (e.g. AWS Secrets Manager, Vault).
BACKUP_ENCRYPTION_PASSPHRASE=changeme-generate-a-strong-passphrase

# ── Object Storage ────────────────────────────────────────────────────────────
BACKUP_S3_BUCKET=my-backup-bucket
BACKUP_S3_PREFIX=homegrown-backups

# For Cloudflare R2 (recommended — zero egress fees):
#   BACKUP_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
#   AWS_ACCESS_KEY_ID=<r2-access-key>
#   AWS_SECRET_ACCESS_KEY=<r2-secret-key>
#   AWS_DEFAULT_REGION=auto

# For AWS S3:
#   BACKUP_S3_ENDPOINT=  (leave empty)
#   AWS_ACCESS_KEY_ID=<iam-access-key>
#   AWS_SECRET_ACCESS_KEY=<iam-secret-key>
#   AWS_DEFAULT_REGION=us-east-1

# For GCS (via S3 interop):
#   BACKUP_S3_ENDPOINT=https://storage.googleapis.com
#   AWS_ACCESS_KEY_ID=<gcs-hmac-access-key>
#   AWS_SECRET_ACCESS_KEY=<gcs-hmac-secret>
#   AWS_DEFAULT_REGION=auto

BACKUP_S3_ENDPOINT=
BACKUP_RETENTION_DAYS=30

# ── Alerting ──────────────────────────────────────────────────────────────────
# Set one or both. Leave empty to disable.

# Slack: Settings → Apps → Incoming Webhooks → Add to Slack
SLACK_WEBHOOK_URL=

# Email (requires sendmail/postfix on the server)
ALERT_EMAIL=

# ── Drill database ────────────────────────────────────────────────────────────
# Temporary database used during restore drills. Dropped after each drill.
DRILL_DB=homegrown_restore_drill
