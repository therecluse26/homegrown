                    "primary_methodology_id": {
                        "type": "string"
                    },
                    "secondary_methodology_ids": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        }
                    },
                    "state_code": {
                        "type": "string"
                    },
                    "student_count": {
                        "type": "integer"
                    },
                    "subscription_tier": {
                        "type": "string"
                    }
                }
            },
            "iam.ParentSummary": {
                "type": "object",
                "properties": {
                    "display_name": {
                        "type": "string"
                    },
                    "id": {
                        "type": "string"
                    },
                    "is_primary": {
                        "type": "boolean"
                    }
                }
