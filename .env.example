# =============================================================================
# Homegrown Academy — Local Development Environment
# Copy to .env and fill in values
# =============================================================================

# Database
DATABASE_URL=postgres://homegrown:homegrown@localhost:5932/homegrown
DATABASE_MAX_CONNECTIONS=5

# Redis
REDIS_URL=redis://localhost:6879

# Auth Provider (Ory Kratos sidecar)
AUTH_ADMIN_URL=http://localhost:4934
AUTH_PUBLIC_URL=http://localhost:4933
AUTH_WEBHOOK_SECRET=

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5673

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=3500

# Logging
LOG_LEVEL=debug

# Environment
ENVIRONMENT=development

# Error Reporting (optional — omit to disable Sentry)
# ERROR_REPORTING_DSN=https://key@sentry.io/project

# Object Storage (optional — omit to use noop adapter in dev)
# OBJECT_STORAGE_ENDPOINT=http://localhost:9000
# OBJECT_STORAGE_REGION=auto
# OBJECT_STORAGE_BUCKET=homegrown-uploads
# OBJECT_STORAGE_ACCESS_KEY_ID=minioadmin
# OBJECT_STORAGE_SECRET_ACCESS_KEY=minioadmin
OBJECT_STORAGE_PUBLIC_URL=https://media.localhost

# Payments (Hyperswitch — optional, omit to disable payments)
# Run `docker compose up hyperswitch-server` then `make hs-setup` to bootstrap
# a local Hyperswitch instance. The setup script prints all values to set here.
# HYPERSWITCH_BASE_URL=http://localhost:8280
# HYPERSWITCH_API_KEY=                     # merchant API key from `make hs-setup`
# HYPERSWITCH_WEBHOOK_KEY=                 # webhook signing secret (set same value for BILLING_WEBHOOK_SECRET)
# HYPERSWITCH_BILLING_PROFILE_ID=          # billing business profile ID from `make hs-setup`
# HYPERSWITCH_MKT_PROFILE_ID=              # marketplace business profile ID from `make hs-setup` [07-mkt §18.5]
# HYPERSWITCH_MONTHLY_PRICE_ID=monthly_plan
# HYPERSWITCH_ANNUAL_PRICE_ID=annual_plan
# COPPA_CHARGE_CENTS=50
# BILLING_WEBHOOK_SECRET=                  # same value as HYPERSWITCH_WEBHOOK_KEY
#
# Billing integration / adapter sandbox tests (go test -tags=integration)
# Set HYPERSWITCH_TEST_PAYMENT_METHOD_ID to a saved test-mode payment method
# created via Hyperswitch dashboard to enable full subscription lifecycle tests.
# HYPERSWITCH_TEST_PAYMENT_METHOD_ID=

# Application public URL (used for absolute links in emails; required in production)
# APP_PUBLIC_URL=https://app.homegrown.academy

# Email (Postmark — optional, omit to use noop adapter)
# POSTMARK_SERVER_TOKEN=
# POSTMARK_FROM_ADDRESS=Homegrown Academy <hello@yourdomain.com>
UNSUBSCRIBE_SECRET=

# Recommendations
# RECS_ANONYMIZATION_SECRET=
